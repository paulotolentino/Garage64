Options -Indexes
DirectoryIndex index.php

ErrorDocument 404 /404.php

# PHP upload limits (mod_php — for PHP-FPM see .user.ini)
<IfModule mod_php8.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 25M
    php_value memory_limit 256M
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 25M
    php_value memory_limit 256M
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Protect sensitive files
<FilesMatch "\.(sql|log|env|ini|lock|json|md)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(setup\.php|composer\.json|composer\.lock)$">
    Require all denied
</FilesMatch>

# Block the web installer once installed.lock exists.
# Uses REQUEST_FILENAME to derive the app directory, so it works in subdirectories too.
<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_FILENAME} ^(.+/)install\.php$
    RewriteCond %1installed.lock -f
    RewriteRule ^install\.php$ - [F,L]

    # Block sensitive directories
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^database/ - [F,L]

    # Serve robots.txt and sitemap.xml via PHP
    RewriteRule ^robots\.txt$ robots.php [L]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # Miniature detail: /mini/{id} or /mini/{id}/{slug}
    RewriteRule ^mini/(\d+)(/[^/]*)?/?$ miniature.php?id=$1 [L,QSA]

    # User collection: /u/{slug}
    RewriteRule ^u/([a-z0-9_-]{2,30})/?$ collection.php?slug=$1 [L,QSA]

    # Clean URLs: strip .php from any page that has a matching .php file
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

# Cache static assets — but NOT uploads (user-edited images must always be fresh)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Uploads must never be aggressively cached (rotation/replace needs to show immediately)
<IfModule mod_headers.c>
    <FilesMatch "^uploads/">
        Header set Cache-Control "no-cache, must-revalidate"
        Header unset Expires
    </FilesMatch>
</IfModule>

# Compress responses
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>
